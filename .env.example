# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Backend API Base URL
# Production:
VITE_API_BASE_URL=https://pearls-erp-2026.onrender.com

# Development (localhost):
# VITE_API_BASE_URL=http://localhost:5000

# Frontend URL (for CORS configuration on backend)
VITE_FRONTEND_URL=https://pearlsfrontend.web.app

# Application Environment
VITE_APP_ENV=production

# NOTE: For development, comment out the production URLs above and uncomment the development ones
